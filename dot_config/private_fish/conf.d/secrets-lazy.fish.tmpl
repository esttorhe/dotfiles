# ABOUTME: Lazy 1Password secret lookups - runs `op read` at interactive shell startup
# ABOUTME: Secrets never land on disk; values live only in the shell env

status is-interactive; or return
type -q op; or return

# Item UUIDs used instead of titles: titles can contain characters op rejects in secret refs

# FitForge - GITHUB TOKEN (Engineering vault, pixeltowers account)
set -l _gh_token (op read --account {{ .op_account_work }} 'op://Engineering/kyl6ugf3ylddze7zc5akxfgzxm/token' 2>/dev/null)
if test -n "$_gh_token"
    set -gx GITHUB_TOKEN "$_gh_token"
end
set -e _gh_token

