# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=$SCRIPT_DIR/$BLOCK_NAME/$BLOCK_NAME
COMMAND2=$SCRIPT_DIR_2/$BLOCK_NAME
separator_block_width=15
markup=pango

#####################################################
# Mail
####################################################
# SoundCloud
[sc-mail]
command=$HOME/.i3blocks/blocks/email
label=’ćÖ sc: 
interval=300
min_width=messages:99
instance=sc_config

# Me
[mail]
command=$HOME/.i3blocks/blocks/email
label=’ćÖ me: 
interval=300
min_width=messages:99
instance=me_config

# Old
[mail]
command=$HOME/.i3blocks/blocks/email
label=’ćÖ old: 
interval=300
min_width=messages:99
instance=old_config
#####################################################

# Notifications
[dunst]
command=$HOME/.i3blocks/blocks/$BLOCK_NAME/$BLOCK_NAME
markup=pango
interval=once
format=json
separator=true
DUNST_MUTE=off

# Volume indicator
#
# The first parameter sets the step (and units to display)
# The second parameter overrides the mixer selection
# See the script for details.
[audio]
label=’Ć© 
interval=5
command=$SCRIPT_DIR_2/$BLOCK_NAME

[microphone]
label=’ä░
interval=5
command=$SCRIPT_DIR_2/$BLOCK_NAME

[webcam]
label=’ĆĮ
instance=/dev/video0
interval=5
command=$SCRIPT_DIR_2/$BLOCK_NAME

[display]
label=’ē¼
interval=5
command=$SCRIPT_DIR_2/$BLOCK_NAME


# Memory usage
#
# The type defaults to "mem" if the instance is not specified.
[memory]
label=’ćĆ
instance=mem;free
interval=30
command=$SCRIPT_DIR_2/$BLOCK_NAME

[memory]
label=’å▓
instance=swap;total
interval=30
command=$SCRIPT_DIR_2/$BLOCK_NAME

[cpu]
label=’éĆ’éģ
interval=2
command=$SCRIPT_DIR_2/$BLOCK_NAME

# Disk usage
#
# The directory defaults to $HOME if the instance is not specified.
# The script may be called with a optional argument to set the alert
# (defaults to 10 for 10%).
[disk]
label=’¤ē 
#DIR=/mnt/data
interval=30

# Shows the number of items in the trash can
[trash]
label=’Ćö
interval=10
command=$SCRIPT_DIR_2/$BLOCK_NAME

# Network interface monitoring
#
# If the instance is not specified, use the interface used for default route.
# The address can be forced to IPv4 or IPv6 with -4 or -6 switches.
[iface]
#IFACE=wlan0
label=’ć½
color=#00FF00
interval=10
separator=false

[vpn]
label=’éä
interval=5
command=$SCRIPT_DIR_2/$BLOCK_NAME

# CPU usage
#
# The script may be called with -w and -c switches to specify thresholds,
# see the script for details.

# Battery indicator
#
# The battery instance defaults to 0.
[battery]
interval=5
command=$HOME/.i3blocks/blocks/$BLOCK_NAME

[weather]
instance=2950159
interval=60
command=$SCRIPT_DIR_2/$BLOCK_NAME

# Date Time
#
[time]
label=’ü│ 
command=date '+%Y-%m-%d %H:%M:%S'
interval=5

